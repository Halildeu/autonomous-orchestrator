{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/enforcement-check.schema.v1.json",
  "title": "Enforcement Check Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "intake_id",
    "run_id",
    "status",
    "rule_set_version",
    "stats",
    "violations",
    "evidence_bundle"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "intake_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "OK",
        "WARN",
        "BLOCKED",
        "FAIL",
        "SKIPPED",
        "UNKNOWN"
      ]
    },
    "rule_set_version": {
      "type": "string",
      "minLength": 1
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline",
        "delta",
        "out_of_scope"
      ],
      "properties": {
        "baseline": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dirty_count",
            "source"
          ],
          "properties": {
            "dirty_count": {
              "type": "integer",
              "minimum": 0
            },
            "source": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "git_commit",
                    "stored_snapshot",
                    "unknown"
                  ]
                },
                "ref": {
                  "type": "string"
                },
                "snapshot_path": {
                  "type": "string"
                }
              }
            }
          }
        },
        "delta": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dirty_count",
            "source"
          ],
          "properties": {
            "dirty_count": {
              "type": "integer",
              "minimum": 0
            },
            "changed_files_count": {
              "type": "integer",
              "minimum": 0
            },
            "source": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "git_diff",
                    "path_list",
                    "unknown"
                  ]
                },
                "ref": {
                  "type": "string"
                },
                "paths": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "out_of_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "violations_count"
          ],
          "properties": {
            "violations_count": {
              "type": "integer",
              "minimum": 0
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "self_hit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "violations_count",
            "status",
            "exclude_globs"
          ],
          "properties": {
            "violations_count": {
              "type": "integer",
              "minimum": 0
            },
            "status": {
              "type": "string",
              "enum": [
                "CLEAN",
                "WARN",
                "FAIL",
                "UNKNOWN"
              ]
            },
            "exclude_globs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "checked_rule_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^EP-[0-9]{3}$"
              }
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "false_positive_baseline": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "window",
            "totals",
            "by_rule"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "PASS",
                "WARN",
                "FAIL",
                "UNKNOWN"
              ]
            },
            "window": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "start_at",
                "end_at"
              ],
              "properties": {
                "start_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "end_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            },
            "totals": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "findings_count",
                "sampled_count",
                "false_positive_count",
                "false_positive_ratio"
              ],
              "properties": {
                "findings_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "sampled_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "false_positive_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "false_positive_ratio": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            },
            "by_rule": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "rule_id",
                  "findings_count",
                  "sampled_count",
                  "false_positive_count",
                  "false_positive_ratio"
                ],
                "properties": {
                  "rule_id": {
                    "type": "string",
                    "pattern": "^EP-[0-9]{3}$"
                  },
                  "findings_count": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "sampled_count": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "false_positive_count": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "false_positive_ratio": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "PASS",
                      "WARN",
                      "FAIL",
                      "UNKNOWN"
                    ]
                  },
                  "notes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "source_report": {
              "type": "string"
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "totals": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "violations_count"
          ],
          "properties": {
            "violations_count": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "classification",
          "severity",
          "message",
          "file_path",
          "start_line",
          "end_line"
        ],
        "properties": {
          "violation_id": {
            "type": "string"
          },
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "engine": {
            "type": "string"
          },
          "engine_rule_id": {
            "type": "string"
          },
          "classification": {
            "type": "string",
            "enum": [
              "BASELINE",
              "DELTA",
              "OUT_OF_SCOPE"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "INFO",
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "file_path": {
            "type": "string",
            "minLength": 1
          },
          "start_line": {
            "type": "integer",
            "minimum": 1
          },
          "end_line": {
            "type": "integer",
            "minimum": 1
          },
          "fingerprint": {
            "type": "string"
          },
          "help": {
            "type": "string"
          },
          "references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "evidence_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_paths"
      ],
      "properties": {
        "bundle_id": {
          "type": "string"
        },
        "evidence_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "baseline_snapshot_path": {
          "type": "string"
        },
        "delta_input_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "raw_tool_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
