                "additionalProperties": false,
                "properties": {
                  "access": {
                    "default": false,
                    "type": "boolean"
                  },
                  "allowlist": {
                    "default": [],
                    "items": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "required": [
                  "access",
                  "allowlist"
                ],
                "type": "object"
              },
              "output_standards": {
                "default": [],
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "type": "array"
              },
              "risk_criteria": {
                "additionalProperties": false,
                "properties": {
                  "approval_risk_threshold": {
