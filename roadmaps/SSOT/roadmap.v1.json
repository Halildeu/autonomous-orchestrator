              "version",
              "tenant_id",
              "enabled_packs",
              "side_effect_policy_limits",
              "allowed_tools",
              "network",
              "output_standards",
              "risk_criteria"
            ],
            "title": "tenant-decision-bundle.schema.json",
            "type": "object"
          },
          "type": "add_schema_file"
        },
        {
          "json": {
            "allowed_tools": [
              "fs_read",
              "fs_write"
            ],
            "enabled_packs": [],
            "network": {
              "access": false,
              "allowlist": []
            },
            "output_standards": [
              "format-recommendation.v1"
            ],
            "risk_criteria": {
              "approval_risk_threshold": 0.7
            },
            "side_effect_policy_limits": {
              "blocked_now": [
                "merge",
                "deploy"
              ],
              "supported_now": [
                "none",
                "draft",
                "pr"
              ]
            },
            "tenant_id": "TENANT-DEFAULT",
            "version": "v1"
          },
          "overwrite": false,
          "path": "tenant/TENANT-DEFAULT/decision-bundle.v1.json",
          "type": "create_json_from_template"
        },
        {
          "content": "import json\nfrom pathlib import Path\n\nfrom jsonschema import Draft202012Validator\n\n\ndef load_json(p: Path):\n    return json.loads(p.read_text(encoding=\"utf-8\"))\n\n\ndef main():\n    root = Path(__file__).resolve().parents[1]\n    schema_path = root / \"schemas\" / \"tenant-decision-bundle.schema.json\"\n    if not schema_path.exists():\n        raise SystemExit(\"Missing schemas/tenant-decision-bundle.schema.json\")\n\n    schema = load_json(schema_path)\n    Draft202012Validator.check_schema(schema)\n    v = Draft202012Validator(schema)\n\n    tenant_dir = root / \"tenant\"\n    if not tenant_dir.exists():\n        print(\"OK: tenant/ not present; skipping.\")\n        return\n\n    bundles = sorted(tenant_dir.glob(\"*/decision-bundle.v1.json\"), key=lambda p: p.as_posix())\n    if not bundles:\n        print(\"OK: no decision bundles found; skipping.\")\n        return\n\n    invalid = 0\n    for bp in bundles:\n        obj = load_json(bp)\n        errors = sorted(v.iter_errors(obj), key=lambda e: e.json_path)\n        if errors:\n            invalid += 1\n            print(f\"INVALID_TENANT_BUNDLE: {bp}\")\n            for err in errors[:10]:\n                where = err.json_path or \"$\"\n                print(f\"  - {where}: {err.message}\")\n\n        # Minimal consistency checks (v0.1): merge/deploy must remain blocked.\n        limits = obj.get(\"side_effect_policy_limits\") if isinstance(obj, dict) else None\n        blocked = limits.get(\"blocked_now\") if isinstance(limits, dict) else None\n        if isinstance(blocked, list) and any(x in {\"merge\", \"deploy\"} for x in blocked) is False:\n            invalid += 1\n            print(f\"INVALID_TENANT_BUNDLE: {bp} (blocked_now must include merge/deploy)\")\n\n    if invalid:\n        raise SystemExit(f\"Tenant consistency failed: {invalid}/{len(bundles)} invalid.\")\n\n    print(f\"OK: {len(bundles)} tenant decision bundles validated.\")\n\n\nif __name__ == \"__main__\":\n    main()\n",
          "overwrite": false,
          "path": "ci/validate_tenant_consistency.py",
          "type": "add_ci_gate_script"
        },
        {
          "text": "Core wiring (CI workflow + policy report injection) is intentionally core-only in v0.3; keep workspace-root runs focused on workspace SSOT files.",
          "type": "note"
        }
      ],
      "title": "Tenant Decision Bundle SSOT v0.1 + Consistency Gate"
