                ],
                "type": "object"
              },
              "side_effect_policy_limits": {
                "additionalProperties": false,
                "properties": {
                  "blocked_now": {
                    "default": [
                      "merge",
                      "deploy"
                    ],
                    "items": {
                      "enum": [
                        "merge",
                        "deploy"
                      ],
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "supported_now": {
                    "default": [
                      "none",
                      "draft"
                    ],
                    "items": {
                      "enum": [
                        "none",
                        "draft",
                        "pr"
                      ],
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "required": [
                  "supported_now",
                  "blocked_now"
                ],
                "type": "object"
              },
              "tenant_id": {
                "minLength": 1,
                "type": "string"
              },
              "version": {
                "const": "v1",
                "type": "string"
              }
            },
