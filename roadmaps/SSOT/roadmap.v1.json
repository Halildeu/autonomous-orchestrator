            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "additionalProperties": false,
            "properties": {
              "allowed_tools": {
                "default": [],
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "type": "array"
              },
              "enabled_packs": {
                "default": [],
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "type": "array"
              },
