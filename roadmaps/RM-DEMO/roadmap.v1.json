{
  "roadmap_id": "RM-DEMO",
  "version": "v1",
  "iso_core_required": false,
  "milestones": [
    {
      "id": "M-DEMO",
      "title": "Roadmap Runner demo (safe, local, deterministic)",
      "constraints": {
        "forbidden_paths": [".env", "evidence/", ".cache/secrets", "dlq/*.json"],
        "max_files_changed": 3,
        "max_diff_lines": 300
      },
      "deliverables": [
        {
          "type": "create_file",
          "path": "docs/OPERATIONS/roadmap-runner-demo.md",
          "content": "# Roadmap Runner Demo\n\nThis file is created by the Roadmap Runner demo roadmap.\n\n- Source: `roadmaps/RM-DEMO/roadmap.v1.json`\n- Note: This is safe and reversible.\n",
          "overwrite": false
        }
      ],
      "gates": [
        {
          "type": "run_cmd",
          "cmd": "python -m src.ops.manage smoke --level fast",
          "must_succeed": true
        },
        { "type": "assert_paths_exist", "paths": ["docs/OPERATIONS/roadmap-runner-demo.md"] }
      ],
      "dod": ["docs/OPERATIONS/roadmap-runner-demo.md exists", "smoke_test passes"]
    }
  ]
}
