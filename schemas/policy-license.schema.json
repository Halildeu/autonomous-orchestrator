{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-license.schema.json",
  "title": "Policy License",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "allowlist",
    "denylist",
    "unknown_behavior"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "allowlist": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "denylist": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unknown_behavior": {
      "type": "string",
      "enum": [
        "warn",
        "fail"
      ]
    },
    "fail_action": {
      "type": "string",
      "enum": [
        "block",
        "warn",
        "log"
      ],
      "description": "Action to take when this policy check fails. block=hard stop, warn=log+continue, log=record only."
    }
  }
}
