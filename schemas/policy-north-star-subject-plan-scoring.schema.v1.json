{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-north-star-subject-plan-scoring.schema.v1.json",
  "title": "North Star Subject Plan Scoring Override",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "quality_gate"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "quality_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scoring_weights"
      ],
      "properties": {
        "scoring_weights": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pair_weight",
            "theme_weight",
            "completeness_weight"
          ],
          "properties": {
            "pair_weight": {
              "type": "number",
              "minimum": 0
            },
            "theme_weight": {
              "type": "number",
              "minimum": 0
            },
            "completeness_weight": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "min_coverage_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_module_count": {
          "type": "integer",
          "minimum": 1
        },
        "require_full_coverage": {
          "type": "boolean"
        },
        "enforce": {
          "type": "boolean"
        }
      }
    }
  }
}
