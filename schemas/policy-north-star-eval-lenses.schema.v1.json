{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-north-star-eval-lenses.schema.v1.json",
  "title": "Policy North Star Eval (Lensless)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "mode",
    "workflow_axes"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "lensless"
      ]
    },
    "workflow_axes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "reference",
          "assessment",
          "gap"
        ]
      },
      "minItems": 3,
      "maxItems": 3
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
