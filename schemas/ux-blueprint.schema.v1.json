{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/ux-blueprint.schema.v1.json",
  "title": "UX Blueprint Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "workspace_root",
    "subject_id",
    "blueprint_id",
    "information_architecture",
    "flows",
    "components",
    "data_contracts",
    "quality_gates",
    "stats"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "blueprint_id": {
      "type": "string",
      "minLength": 1
    },
    "information_architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_id",
        "layout",
        "navigation_model",
        "regions"
      ],
      "properties": {
        "page_id": {
          "type": "string",
          "minLength": 1
        },
        "layout": {
          "type": "string",
          "minLength": 1
        },
        "navigation_model": {
          "type": "string",
          "minLength": 1
        },
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/flow"
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "data_contracts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/data_contract"
      }
    },
    "quality_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_count",
        "subsection_count"
      ],
      "properties": {
        "section_count": {
          "type": "integer",
          "minimum": 0
        },
        "subsection_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow_id",
        "actor",
        "steps"
      ],
      "properties": {
        "flow_id": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/flow_step"
          }
        }
      }
    },
    "flow_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "action",
        "outcome"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "source",
        "role",
        "props_contract"
      ],
      "properties": {
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "props_contract": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "data_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "source",
        "fields"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
