{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ao:context-evolution-proposal:v1",
  "title": "Context Evolution Proposal",
  "description": "ACE evolution cycle output — proposals to prune, promote, demote, or add rules.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "status", "proposals_count", "proposals"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["OK", "SKIP"] },
    "total_rules_analyzed": { "type": "integer", "minimum": 0 },
    "proposals_count": { "type": "integer", "minimum": 0 },
    "auto_applied_count": { "type": "integer", "minimum": 0 },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposal_id", "type", "target_rule", "reason", "confidence"],
        "properties": {
          "proposal_id": { "type": "string", "pattern": "^EVO-" },
          "type": { "type": "string", "enum": ["prune", "add", "modify", "promote", "demote"] },
          "target_rule": { "type": "string" },
          "reason": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "auto_applied": { "type": "boolean" },
          "applied_at": { "type": "string" },
          "rollback_available": { "type": "boolean" },
          "requires_human_review": { "type": "boolean" }
        }
      }
    },
    "tier_summary": { "type": "object" },
    "reason": { "type": "string" }
  }
}
