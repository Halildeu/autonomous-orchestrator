{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/planner-step.schema.v1.json",
  "title": "Planner Step",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "step_id",
    "type",
    "ops",
    "expected_outputs"
  ],
  "properties": {
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "ops": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
