{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/authority-matrix.schema.json",
  "title": "authority-matrix.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "kind",
    "project_id",
    "status",
    "precedence_order",
    "layers",
    "conflict_rules",
    "surfaces"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "kind": {
      "const": "authority-matrix"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "precedence_order": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "layer_id",
          "conflict_precedence",
          "allowed_write_mode"
        ],
        "properties": {
          "layer_id": {
            "type": "string",
            "minLength": 1
          },
          "conflict_precedence": {
            "type": "integer",
            "minimum": 1
          },
          "allowed_write_mode": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "conflict_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "when",
          "winner_layer"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "when": {
            "type": "string",
            "minLength": 1
          },
          "winner_layer": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_id",
          "concern",
          "layer_id",
          "repo_scope",
          "owner",
          "authority_state",
          "effective_paths",
          "supporting_paths",
          "archive_paths",
          "write_policy"
        ],
        "properties": {
          "surface_id": {
            "type": "string",
            "minLength": 1
          },
          "concern": {
            "type": "string",
            "minLength": 1
          },
          "layer_id": {
            "type": "string",
            "minLength": 1
          },
          "repo_scope": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "authority_state": {
            "type": "string",
            "minLength": 1
          },
          "effective_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "supporting_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "archive_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "write_policy": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
