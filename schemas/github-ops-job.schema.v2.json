{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/github-ops-job.schema.v2.json",
  "title": "GitHub Ops Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "job_id",
    "kind",
    "status",
    "created_at",
    "updated_at",
    "workspace_root",
    "dry_run",
    "live_gate",
    "signature_hash",
    "evidence_paths",
    "notes"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["v2"] },
    "job_id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": [
        "pr_list",
        "pr_open",
        "pr_update",
        "merge",
        "deploy_trigger",
        "status_poll",
        "PR_LIST",
        "PR_OPEN",
        "PR_UPDATE",
        "PR_POLL",
        "CI_POLL",
        "MERGE",
        "RELEASE_RC",
        "RELEASE_FINAL",
        "SMOKE_FAST",
        "SMOKE_FULL",
        "DEPLOY_TRIGGER",
        "STATUS_POLL"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["QUEUED", "RUNNING", "PASS", "FAIL", "TIMEOUT", "KILLED", "SKIP", "ARCHIVED"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": "string", "format": "date-time" },
    "last_poll_at": { "type": "string", "format": "date-time" },
    "archived_at": { "type": "string", "format": "date-time" },
    "archived": { "type": "boolean" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "dry_run": { "type": "boolean" },
    "live_gate": { "type": "boolean" },
    "attempts": { "type": "integer", "minimum": 0 },
    "pid": { "type": "integer" },
    "rc": { "type": "integer" },
    "error_code": { "type": "string" },
    "skip_reason": { "type": "string" },
    "failure_class": {
      "type": "string",
      "enum": [
        "PASS",
        "TIMEOUT",
        "DEMO_PREREQ_FAIL",
        "DEMO_PREREQ_APPLY_FAIL",
        "DEMO_ADVISOR_SUGGESTIONS_MISSING",
        "DEMO_CATALOG_MISSING",
        "DEMO_CATALOG_PARSE",
        "DEMO_PUBLIC_CANDIDATES_POINTER_MISSING",
        "DEMO_PACK_CAPABILITY_INDEX_MISSING",
        "DEMO_M9_3_APPLY_MUST_WRITE_PACK_SELECTION_TRACE_V1_JSON",
        "DEMO_OTHER_MARKER_2472D115C490",
        "DEMO_QUALITY_GATE_REPORT_MISSING",
        "DEMO_SESSION_CONTEXT_HASH_MISMATCH",
        "DEMO_SESSION_CONTEXT_MISSING",
        "CORE_BREAK",
        "POLICY_TIME_LIMIT",
        "AUTH",
        "PERMISSION",
        "VALIDATION",
        "NOT_FOUND",
        "CONFLICT",
        "RATE_LIMIT",
        "NETWORK",
        "OTHER"
      ]
    },
    "http_status": { "type": "integer" },
    "gh_error_code": { "type": "string" },
    "gh_request_id": { "type": "string" },
    "endpoint": { "type": "string" },
    "message_redacted": { "type": "string", "maxLength": 200 },
    "message_hash": { "type": "string", "minLength": 1 },
    "retry_after_seconds": { "type": "integer", "minimum": 0 },
    "pr_url": { "type": "string" },
    "pr_html_url": { "type": "string" },
    "pr_number": { "type": "integer", "minimum": 1 },
    "pr_state": { "type": "string" },
    "pr_base": { "type": "string" },
    "pr_head": { "type": "string" },
    "signature_hash": { "type": "string", "minLength": 1 },
    "trace_meta": { "$ref": "https://example.com/schemas/trace-meta.schema.v1.json" },
    "evidence_paths": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "result_paths": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
