{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "roadmap.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["roadmap_id", "version", "milestones"],
  "properties": {
    "roadmap_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Z0-9][A-Z0-9_-]{2,64}$"
    },
    "version": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16,
      "pattern": "^v[0-9]+$"
    },
    "iso_core_required": { "type": "boolean", "default": false },
    "global_gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" },
      "default": []
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/milestone" }
    }
  },
  "$defs": {
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "forbidden_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "max_files_changed": { "type": "integer", "minimum": 0 },
        "max_diff_lines": { "type": "integer", "minimum": 0 }
      }
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "gates", "dod"],
      "anyOf": [{ "required": ["steps"] }, { "required": ["deliverables"] }],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Z0-9][A-Z0-9_.-]{0,63}$"
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" },
          "default": []
        },
        "deliverables": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" },
          "default": []
        },
        "gates": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" },
          "default": []
        },
        "constraints": { "$ref": "#/$defs/constraints" },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "dod": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "status": {
          "type": "string",
          "enum": ["open", "in_progress", "done", "blocked"],
          "default": "open",
          "description": "Milestone lifecycle status."
        }
      }
    },
    "text_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "replacement"],
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "replacement": { "type": "string" }
      }
    },
    "step": {
      "oneOf": [
        { "$ref": "#/$defs/step_note" },
        { "$ref": "#/$defs/step_create_file" },
        { "$ref": "#/$defs/step_ensure_dir" },
        { "$ref": "#/$defs/step_workspace_root_guard" },
        { "$ref": "#/$defs/step_write_file_allowlist" },
        { "$ref": "#/$defs/step_patch_file" },
        { "$ref": "#/$defs/step_create_json_from_template" },
        { "$ref": "#/$defs/step_add_schema_file" },
        { "$ref": "#/$defs/step_add_ci_gate_script" },
        { "$ref": "#/$defs/step_patch_policy_report_inject" },
        { "$ref": "#/$defs/step_change_proposal_apply" },
        { "$ref": "#/$defs/step_incubator_sanitize_scan" },
        { "$ref": "#/$defs/step_run_cmd" },
        { "$ref": "#/$defs/step_assert_paths_exist" },
        { "$ref": "#/$defs/step_assert_pointer_target_exists" },
        { "$ref": "#/$defs/step_assert_core_paths_exist" },
        { "$ref": "#/$defs/step_iso_core_check" }
      ]
    },
    "step_note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "note" },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "step_create_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path", "content", "overwrite"],
      "properties": {
        "type": { "const": "create_file" },
        "path": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "overwrite": { "type": "boolean" }
      }
    },
    "step_ensure_dir": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": { "const": "ensure_dir" },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "step_workspace_root_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "paths"],
      "properties": {
        "type": { "const": "workspace_root_guard" },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "step_write_file_allowlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "allowed_paths"],
      "properties": {
        "type": { "const": "write_file_allowlist" },
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "step_patch_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path", "patches"],
      "properties": {
        "type": { "const": "patch_file" },
        "path": { "type": "string", "minLength": 1 },
        "patches": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/text_patch" }
        }
      }
    },
    "step_create_json_from_template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path", "json", "overwrite"],
      "properties": {
        "type": { "const": "create_json_from_template" },
        "path": { "type": "string", "minLength": 1 },
        "json": { "type": "object" },
        "overwrite": { "type": "boolean" }
      }
    },
    "step_add_schema_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path", "schema_json"],
      "properties": {
        "type": { "const": "add_schema_file" },
        "path": { "type": "string", "minLength": 1 },
        "schema_json": { "type": "object" }
      }
    },
    "step_add_ci_gate_script": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path", "content", "overwrite"],
      "properties": {
        "type": { "const": "add_ci_gate_script" },
        "path": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "overwrite": { "type": "boolean" }
      }
    },
    "step_patch_policy_report_inject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "target", "marker", "insert_text"],
      "properties": {
        "type": { "const": "patch_policy_report_inject" },
        "target": { "type": "string", "minLength": 1 },
        "marker": { "type": "string", "minLength": 1 },
        "insert_text": { "type": "string" }
      }
    },
    "step_change_proposal_apply": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "change_path"],
      "properties": {
        "type": { "const": "change_proposal_apply" },
        "change_path": { "type": "string", "minLength": 1 },
        "roadmap_path": { "type": "string", "minLength": 1 }
      }
    },
    "step_incubator_sanitize_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": { "const": "incubator_sanitize_scan" },
        "path": { "type": "string", "minLength": 1 },
        "forbidden_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "step_run_cmd": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "cmd", "must_succeed"],
      "properties": {
        "type": { "const": "run_cmd" },
        "cmd": { "type": "string", "minLength": 1 },
        "must_succeed": { "type": "boolean" },
        "apply_only": { "type": "boolean", "default": false }
      }
    },
    "step_assert_paths_exist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "paths"],
      "properties": {
        "type": { "const": "assert_paths_exist" },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "apply_only": { "type": "boolean", "default": false }
      }
    },
    "step_assert_pointer_target_exists": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "pointer_path"],
      "properties": {
        "type": { "const": "assert_pointer_target_exists" },
        "pointer_path": { "type": "string", "minLength": 1 },
        "apply_only": { "type": "boolean", "default": false }
      }
    },
    "step_assert_core_paths_exist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "paths"],
      "properties": {
        "type": { "const": "assert_core_paths_exist" },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "step_iso_core_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tenant", "required_files"],
      "properties": {
        "type": { "const": "iso_core_check" },
        "tenant": { "type": "string", "minLength": 1 },
        "required_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
