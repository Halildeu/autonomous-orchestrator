{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "provider-performance.schema.v1.json",
  "title": "Provider Performance",
  "description": "Runtime performance metrics per AI provider/model for benchmarking and selection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "providers"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["total_calls", "success_rate"],
        "properties": {
          "total_calls": { "type": "integer", "minimum": 0 },
          "success_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "avg_latency_ms": { "type": "integer", "minimum": 0 },
          "p95_latency_ms": { "type": "integer", "minimum": 0 },
          "error_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "avg_output_tokens": { "type": "integer", "minimum": 0 },
          "quality_gate_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "last_updated": { "type": "string" },
          "trend": { "type": "string", "enum": ["improving", "stable", "degrading"] }
        }
      }
    }
  }
}
