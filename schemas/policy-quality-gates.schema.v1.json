{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "policy-quality-gates.schema.v1.json",
  "title": "Policy Quality Gates",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "enabled", "gates"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "enabled": { "type": "boolean" },
    "gates": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "on_fail"],
        "properties": {
          "enabled": { "type": "boolean" },
          "on_fail": { "type": "string", "enum": ["pass", "retry", "reject", "warn", "escalate", "suspend"] },
          "max_retries": { "type": "integer", "minimum": 0 },
          "min_output_chars": { "type": "integer", "minimum": 0 },
          "check_against": { "type": "string" }
        }
      }
    },
    "fallback_on_all_fail": { "type": "string", "enum": ["pass", "reject", "suspend"] }
  }
}
