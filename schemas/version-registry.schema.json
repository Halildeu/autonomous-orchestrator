{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/version-registry.schema.json",
  "title": "version-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "kind",
    "project_id",
    "status",
    "targets"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "kind": {
      "const": "version-registry"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_id",
          "repo_root",
          "version_sources",
          "toolchain_sources",
          "runtime_sources",
          "lockfile_sources",
          "status"
        ],
        "properties": {
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "repo_root": {
            "type": "string",
            "minLength": 1
          },
          "version_sources": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/sourceRef"
            }
          },
          "toolchain_sources": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/sourceRef"
            }
          },
          "runtime_sources": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/sourceRef"
            }
          },
          "lockfile_sources": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/sourceRef"
            }
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
