{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/spec-core.schema.json",
  "title": "spec-core.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "body"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "kind", "purpose", "outputs", "guardrails"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^[A-Z][A-Z0-9_-]{2,127}$"
        },
        "version": {
          "type": "string",
          "minLength": 2,
          "maxLength": 16,
          "pattern": "^v[0-9]+(\\.[0-9]+)*$"
        },
        "kind": {
          "type": "string",
          "enum": ["CAPABILITY", "PACK", "FORMAT", "OPERATION"]
        },
        "purpose": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "inputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "steps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "guardrails": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "iso_refs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "context_ref": { "type": "string", "minLength": 1 },
            "stakeholders_ref": { "type": "string", "minLength": 1 },
            "scope_ref": { "type": "string", "minLength": 1 },
            "criteria_ref": { "type": "string", "minLength": 1 },
            "gate_level": { "type": "string", "enum": ["warn", "block"], "default": "block" }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expected", "verify_on_read"],
          "properties": {
            "expected": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "default": []
            },
            "verify_on_read": { "type": "boolean", "default": true }
          }
        },
        "risk": {
          "type": "object",
          "additionalProperties": false,
          "required": ["category", "default_mode"],
          "properties": {
            "category": { "type": "string", "enum": ["low", "medium", "high"] },
            "default_mode": { "type": "string", "enum": ["normal", "report_only", "quarantine"] },
            "triggers": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "default": []
            }
          }
        },
        "sustainability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "intent": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "default": []
            },
            "metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "target"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "target": { "type": "string", "minLength": 1 }
                }
              },
              "default": []
            }
          }
        },
        "continuity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["resume_supported", "idempotent", "checkpointing"],
          "properties": {
            "resume_supported": { "type": "boolean" },
            "idempotent": { "type": "boolean" },
            "checkpointing": { "type": "boolean" }
          }
        }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

