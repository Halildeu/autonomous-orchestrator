{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/apps-and-launch-registry.schema.json",
  "title": "apps-and-launch-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "kind",
    "project_id",
    "status",
    "profiles"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "kind": {
      "const": "apps-and-launch-registry"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "app_id",
          "target_id",
          "display_name",
          "status",
          "launch_mode",
          "working_dir",
          "command",
          "ports",
          "source_refs"
        ],
        "properties": {
          "app_id": {
            "type": "string",
            "minLength": 1
          },
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "launch_mode": {
            "type": "string",
            "minLength": 1
          },
          "working_dir": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "ports": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            }
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
