{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context-bootstrap-report.schema.v1.json",
  "title": "Context Bootstrap Report",
  "description": "Validates presence, freshness, and schema validity of 3-tier context bootstrap files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "workspace_root", "tiers", "status"],
  "properties": {
    "version": { "const": "v1" },
    "generated_at": { "type": "string", "minLength": 1 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "tiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tier", "name", "files", "status"],
        "properties": {
          "tier": { "type": "integer", "minimum": 1, "maximum": 3 },
          "name": { "type": "string" },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "exists"],
              "properties": {
                "path": { "type": "string" },
                "exists": { "type": "boolean" },
                "fresh": { "type": "boolean" },
                "schema_valid": { "type": "boolean" },
                "age_seconds": { "type": "integer" },
                "issues": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "status": { "type": "string", "enum": ["OK", "WARN", "FAIL"] }
        }
      }
    },
    "status": { "type": "string", "enum": ["OK", "FAIL"] },
    "issues": { "type": "array", "items": { "type": "string" } }
  }
}
