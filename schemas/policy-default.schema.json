{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-default.schema.json",
  "title": "Policy Default",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "policies"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "policies": {
      "type": "array",
      "items": { "type": "string", "pattern": "^policies\\/policy_[a-z0-9_]+\\.v[0-9]+\\.json$" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
