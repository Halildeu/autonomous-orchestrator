{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-docs-classifier.schema.v1.json",
  "title": "Policy Docs Classifier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "rules",
    "outputs",
    "thresholds"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_json",
        "report_md"
      ],
      "properties": {
        "report_json": {
          "type": "string",
          "minLength": 1
        },
        "report_md": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unmapped_warn",
        "unmapped_fail"
      ],
      "properties": {
        "unmapped_warn": {
          "type": "integer",
          "minimum": 0
        },
        "unmapped_fail": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "fail_action": {
      "type": "string",
      "enum": [
        "block",
        "warn",
        "log"
      ],
      "description": "Action to take when this policy check fails. block=hard stop, warn=log+continue, log=record only."
    }
  },
  "$defs": {
    "rule": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "enum": [
                "ssot_map_refs",
                "extension_manifest_docs_ref"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "globs"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "enum": [
                "view_allowlist_globs"
              ]
            },
            "globs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "prefixes"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "enum": [
                "path_prefix"
              ]
            },
            "prefixes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    }
  }
}
