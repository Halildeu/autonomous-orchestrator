{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ao:policy-project-cards:v1",
  "title": "Project Cards Policy",
  "description": "Project context card registry — groups projects with shared conventions and extension references.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "groups", "resolution"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "description": { "type": "string" },
    "groups": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["projects", "shared_rules"],
        "properties": {
          "projects": { "type": "array", "items": { "type": "string" } },
          "extension_ref": { "type": "string" },
          "shared_rules": { "type": "string" },
          "shared_tech_stack": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "resolution": {
      "type": "object",
      "required": ["source", "fallback"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "fallback": { "type": "string" }
      }
    }
  }
}
