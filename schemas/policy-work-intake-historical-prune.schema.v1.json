{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-work-intake-historical-prune.schema.v1.json",
  "title": "policy-work-intake-historical-prune",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "enabled",
    "auto_run_on_work_intake_check",
    "github_ops"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "enabled": { "type": "boolean" },
    "auto_run_on_work_intake_check": { "type": "boolean" },
    "github_ops": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "prune_superseded_by_pass", "archive_reason"],
      "properties": {
        "enabled": { "type": "boolean" },
        "prune_superseded_by_pass": { "type": "boolean" },
        "archive_reason": { "type": "string", "minLength": 1 }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
