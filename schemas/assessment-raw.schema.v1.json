{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/assessment-raw.schema.v1.json",
  "title": "Assessment Raw",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "workspace_root",
    "status",
    "integrity_snapshot_ref",
    "source_hashes",
    "inputs",
    "notes"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["OK", "WARN", "SKIPPED"] },
    "integrity_snapshot_ref": { "type": "string", "minLength": 1 },
    "source_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_status",
        "pack_index",
        "quality_gate",
        "repo_hygiene",
        "harvest",
        "script_budget"
      ],
      "properties": {
        "system_status": { "type": ["string", "null"] },
        "pack_index": { "type": ["string", "null"] },
        "quality_gate": { "type": ["string", "null"] },
        "repo_hygiene": { "type": ["string", "null"] },
        "harvest": { "type": ["string", "null"] },
        "script_budget": { "type": ["string", "null"] }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packs", "controls", "metrics", "warnings"],
      "properties": {
        "packs": { "type": "integer", "minimum": 0 },
        "controls": { "type": "integer", "minimum": 0 },
        "metrics": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "script_budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hard_exceeded", "soft_exceeded"],
          "properties": {
            "hard_exceeded": { "type": "integer", "minimum": 0 },
            "soft_exceeded": { "type": "integer", "minimum": 0 },
            "top_offenders": { "type": "array", "items": { "type": "string" } },
            "report_path": { "type": "string" }
          }
        },
        "doc_nav": {
          "type": "object",
          "additionalProperties": false,
          "required": ["placeholders_count", "broken_refs", "orphan_critical"],
          "properties": {
            "placeholders_count": { "type": "integer", "minimum": 0 },
            "broken_refs": { "type": "integer", "minimum": 0 },
            "orphan_critical": { "type": "integer", "minimum": 0 },
            "report_path": { "type": "string" }
          }
        },
        "airunner_jobs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["queued", "running", "fail", "pass", "stuck"],
          "properties": {
            "queued": { "type": "integer", "minimum": 0 },
            "running": { "type": "integer", "minimum": 0 },
            "fail": { "type": "integer", "minimum": 0 },
            "pass": { "type": "integer", "minimum": 0 },
            "stuck": { "type": "integer", "minimum": 0 },
            "last_job_age_seconds": { "type": "integer", "minimum": 0 },
            "jobs_index_path": { "type": "string" }
          }
        },
        "pdca_cursor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["stale_hours"],
          "properties": {
            "stale_hours": { "type": "number", "minimum": 0 },
            "cursor_hash": { "type": "string" },
            "last_updated": { "type": "string", "format": "date-time" }
          }
        },
        "airunner_heartbeat": {
          "type": "object",
          "additionalProperties": false,
          "required": ["stale_seconds"],
          "properties": {
            "stale_seconds": { "type": "integer", "minimum": 0 },
            "lock_state": { "type": "string" },
            "heartbeat_path": { "type": "string" }
          }
        },
        "work_intake_noise": {
          "type": "object",
          "additionalProperties": false,
          "required": ["new_items_24h", "suppressed_24h"],
          "properties": {
            "new_items_24h": { "type": "integer", "minimum": 0 },
            "suppressed_24h": { "type": "integer", "minimum": 0 }
          }
        },
        "integrity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "type": "string", "enum": ["PASS", "WARN", "FAIL", "UNKNOWN"] }
          }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
