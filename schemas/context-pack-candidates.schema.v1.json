{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/context-pack-candidates.schema.v1.json",
  "title": "Context Pack Candidates",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "workspace_root", "candidates"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate" }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_id", "model_id", "response_path", "content_hash"],
      "properties": {
        "provider_id": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "response_path": { "type": "string", "minLength": 1 },
        "content_hash": { "type": "string", "minLength": 8 }
      }
    }
  }
}
