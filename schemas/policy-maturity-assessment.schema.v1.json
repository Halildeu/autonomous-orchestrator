{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ao:policy-maturity-assessment:v1",
  "title": "Maturity Assessment Policy Schema",
  "description": "Validates the maturity assessment rubric policy. Defines per-area scoring criteria, evidence requirements, and level definitions used by all agents.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "$schema": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "assessment_protocol": {
      "type": "object",
      "properties": {
        "branch_rule": { "type": "string" },
        "execution_rule": { "type": "string" },
        "scoring_rule": { "type": "string" },
        "conflict_resolution": { "type": "string" }
      },
      "required": ["branch_rule", "execution_rule", "scoring_rule", "conflict_resolution"],
      "additionalProperties": false
    },
    "areas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "area_id": {
            "type": "string",
            "enum": [
              "state_machine",
              "crash_consistency",
              "decision_mechanism",
              "rule_composition",
              "ci_gates",
              "policy_coverage",
              "extensions",
              "multi_agent",
              "observability",
              "test_coverage"
            ]
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence_commands": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "evidence_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "criteria": {
            "type": "object",
            "properties": {
              "l0_definition": { "type": "string" },
              "l1_definition": { "type": "string" },
              "l2_definition": { "type": "string" },
              "l3_definition": { "type": "string" },
              "l4_definition": { "type": "string" }
            },
            "required": ["l0_definition", "l1_definition", "l2_definition", "l3_definition", "l4_definition"],
            "additionalProperties": false
          }
        },
        "required": ["area_id", "weight", "evidence_commands", "evidence_files", "criteria"],
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": ["version", "description", "assessment_protocol", "areas"],
  "additionalProperties": true
}
