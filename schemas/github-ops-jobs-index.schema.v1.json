{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/github-ops-jobs-index.schema.v1.json",
  "title": "GitHub Ops Jobs Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "workspace_root", "status", "jobs", "counts", "notes"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["OK", "WARN", "IDLE", "FAIL"] },
    "jobs": {
      "type": "array",
      "items": { "$ref": "https://example.com/schemas/github-ops-job.schema.v1.json" }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "queued", "running", "pass", "fail", "timeout", "killed", "skip"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "queued": { "type": "integer", "minimum": 0 },
        "running": { "type": "integer", "minimum": 0 },
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "timeout": { "type": "integer", "minimum": 0 },
        "killed": { "type": "integer", "minimum": 0 },
        "skip": { "type": "integer", "minimum": 0 }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
