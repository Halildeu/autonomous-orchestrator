{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-preflight-stamp.schema.v1.json",
  "title": "Policy: Preflight Stamp",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "stamp_ttl_minutes", "require_pass_for_apply"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
