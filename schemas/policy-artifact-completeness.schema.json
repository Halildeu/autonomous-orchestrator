{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-artifact-completeness.schema.json",
  "title": "Policy Artifact Completeness",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "enabled", "checks"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "enabled": { "type": "boolean" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "owner_milestone", "severity", "auto_heal"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "owner_milestone": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["warn", "block"] },
          "auto_heal": { "type": "boolean" }
        }
      }
    },
    "note": { "type": "string" }
  }
}
