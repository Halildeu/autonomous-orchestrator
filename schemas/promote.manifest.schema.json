{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "promote.manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "items"],
  "properties": {
    "version": { "type": "string", "const": "v1" },
    "created_at": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" },
      "default": []
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["file", "dir", "template", "policy", "schema", "doc"]
        },
        "note": { "type": "string" }
      }
    }
  }
}
