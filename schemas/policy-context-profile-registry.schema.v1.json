{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ao:policy-context-profile-registry:v1",
  "title": "Policy Context Profile Registry",
  "description": "Schema for policy_context_profile_registry.v1.json — validates the 6-profile context loading registry (STARTUP, EMERGENCY, TASK_EXECUTION, REVIEW, ASSESSMENT, PLANNING).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "default_profile", "profiles"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "enum": ["v1"] },
    "default_profile": { "type": "string", "minLength": 1 },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["profile_id", "title", "description", "sections", "required_files", "bootstrap_commands"],
        "properties": {
          "profile_id": {
            "type": "string",
            "enum": ["STARTUP", "TASK_EXECUTION", "REVIEW", "ASSESSMENT", "EMERGENCY", "PLANNING"]
          },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "trigger_conditions": { "type": "array", "items": { "type": "object" } },
          "sections": {
            "type": "object",
            "required": ["required", "optional"],
            "properties": {
              "required": { "type": "array", "items": { "type": "string" } },
              "optional": { "type": "array", "items": { "type": "string" } },
              "forbidden": { "type": "array", "items": { "type": "string" } }
            }
          },
          "required_files": { "type": "array", "items": { "type": "string" } },
          "optional_files": { "type": "array", "items": { "type": "string" } },
          "guardrails_override": { "type": "object" },
          "bootstrap_commands": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "task_scope_hints": { "type": "array", "items": { "type": "string" } },
          "agent_notes": { "type": "string" }
        }
      }
    }
  }
}
