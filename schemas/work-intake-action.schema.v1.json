{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/work-intake-action.schema.v1.json",
  "title": "Work Intake Action",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "workspace_root",
    "intake_id",
    "action_kind",
    "apply_scope",
    "status"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "intake_id": { "type": "string", "minLength": 1 },
    "action_kind": {
      "type": "string",
      "enum": ["APPLY_WORKSPACE_PATCH", "APPLY_INCUBATOR_CHG", "WRITE_DOC_NOTE", "NOOP"]
    },
    "apply_scope": { "type": "string", "enum": ["WORKSPACE_ONLY"] },
    "status": { "type": "string", "enum": ["APPLIED", "PLANNED", "IDLE"] },
    "reason": { "type": "string" },
    "plan_path": { "type": "string" },
    "note_path": { "type": "string" },
    "source_type": { "type": "string" },
    "source_ref": { "type": "string" },
    "evidence_paths": { "type": "array", "items": { "type": "string" } }
  }
}
