{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/ux-interaction-matrix.schema.v1.json",
  "title": "UX Interaction Matrix Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "workspace_root",
    "subject_id",
    "rows"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/matrix_row"
      }
    }
  },
  "$defs": {
    "matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interaction_id",
        "component_id",
        "trigger",
        "event",
        "states",
        "accessibility",
        "expected_result"
      ],
      "properties": {
        "interaction_id": {
          "type": "string",
          "minLength": 1
        },
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string",
          "enum": [
            "click",
            "keyboard",
            "system"
          ]
        },
        "event": {
          "type": "string",
          "minLength": 1
        },
        "states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "accessibility": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_result": {
          "type": "string",
          "minLength": 1
        },
        "telemetry_event": {
          "type": "string"
        }
      }
    }
  }
}
