{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/planner-plan.schema.v1.json",
  "title": "Planner Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "plan_id",
    "created_at",
    "scope",
    "inputs",
    "decision",
    "steps",
    "evidence_paths"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["v1"]
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_root",
        "mode"
      ],
      "properties": {
        "workspace_root": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_intake_path",
        "system_status_path",
        "assessment_eval_path",
        "gap_register_path"
      ],
      "properties": {
        "work_intake_path": {
          "type": "string"
        },
        "system_status_path": {
          "type": "string"
        },
        "assessment_eval_path": {
          "type": "string"
        },
        "gap_register_path": {
          "type": "string"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "why",
        "selected_intake_ids",
        "selected_extensions",
        "limits_applied"
      ],
      "properties": {
        "why": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selected_intake_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selected_extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limits_applied": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_steps",
            "max_plan_bytes",
            "max_chg_drafts",
            "max_selected_items",
            "max_reason_lines"
          ],
          "properties": {
            "max_steps": {
              "type": "integer",
              "minimum": 0
            },
            "max_plan_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "max_chg_drafts": {
              "type": "integer",
              "minimum": 0
            },
            "max_selected_items": {
              "type": "integer",
              "minimum": 0
            },
            "max_reason_lines": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "schemas/planner-step.schema.v1.json"
      }
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
