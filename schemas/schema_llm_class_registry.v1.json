{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "llm_class_registry",
  "type": "object",
  "required": ["policy_version", "classes"],
  "properties": {
    "policy_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["class_id", "active_core", "modality", "verified_only_default", "allowed_intents"],
        "properties": {
          "class_id": { "type": "string" },
          "active_core": { "type": "boolean" },
          "modality": { "type": "string" },
          "verified_only_default": { "type": "boolean" },
          "allowed_intents": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
