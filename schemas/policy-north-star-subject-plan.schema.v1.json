{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-north-star-subject-plan.schema.v1.json",
  "title": "North Star Subject Plan Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "synthesis",
    "quality_gate",
    "limits"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "synthesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "stopwords",
        "module_blueprints"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "stopwords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "module_blueprints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "module_id",
              "title_tr",
              "title_en",
              "module_kind",
              "keywords",
              "flow"
            ],
            "properties": {
              "module_id": {
                "type": "string",
                "minLength": 1
              },
              "title_tr": {
                "type": "string",
                "minLength": 1
              },
              "title_en": {
                "type": "string",
                "minLength": 1
              },
              "module_kind": {
                "type": "string",
                "minLength": 1
              },
              "keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "flow": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "inputs",
                  "process",
                  "outputs"
                ],
                "properties": {
                  "inputs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "process": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "outputs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "quality_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enforce",
        "max_module_count",
        "min_coverage_quality",
        "require_full_coverage",
        "scoring_weights"
      ],
      "properties": {
        "enforce": {
          "type": "boolean"
        },
        "max_module_count": {
          "type": "integer",
          "minimum": 1
        },
        "min_coverage_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "require_full_coverage": {
          "type": "boolean"
        },
        "preferred_profile_order": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C"
            ]
          }
        },
        "scoring_weights": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pair_weight",
            "theme_weight",
            "completeness_weight"
          ],
          "properties": {
            "pair_weight": {
              "type": "number",
              "minimum": 0
            },
            "theme_weight": {
              "type": "number",
              "minimum": 0
            },
            "completeness_weight": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_steps",
        "max_plan_bytes"
      ],
      "properties": {
        "max_steps": {
          "type": "integer",
          "minimum": 2
        },
        "max_plan_bytes": {
          "type": "integer",
          "minimum": 4096
        },
        "plan_bytes_over_limit_action": {
          "type": "string",
          "enum": [
            "warn",
            "fail"
          ]
        }
      }
    },
    "fail_action": {
      "type": "string",
      "enum": [
        "block",
        "warn",
        "log"
      ],
      "description": "Action to take when this policy check fails. block=hard stop, warn=log+continue, log=record only."
    }
  }
}
