{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/airunner-proof-bundle.schema.v1.json",
  "title": "Airunner Proof Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "workspace_root",
    "baseline_path",
    "run_path",
    "deltas_path",
    "tick1_path",
    "tick2_path",
    "proof_path",
    "seed_audit_path",
    "poll_only_observed",
    "start_only_observed",
    "tick1_ops",
    "tick2_ops",
    "jobs_polled_delta",
    "jobs_started_delta",
    "intake_new_items_delta",
    "suppressed_delta"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "workspace_root": { "type": "string", "minLength": 1 },
    "baseline_path": { "type": "string", "minLength": 1 },
    "run_path": { "type": "string", "minLength": 1 },
    "deltas_path": { "type": "string", "minLength": 1 },
    "tick1_path": { "type": "string", "minLength": 1 },
    "tick2_path": { "type": "string", "minLength": 1 },
    "proof_path": { "type": "string", "minLength": 1 },
    "seed_audit_path": { "type": "string", "minLength": 1 },
    "poll_only_observed": { "type": "boolean" },
    "start_only_observed": { "type": "boolean" },
    "tick1_ops": { "type": "array", "items": { "type": "string" } },
    "tick2_ops": { "type": "array", "items": { "type": "string" } },
    "jobs_polled_delta": { "type": "integer" },
    "jobs_started_delta": { "type": "integer" },
    "intake_new_items_delta": { "type": "integer" },
    "suppressed_delta": { "type": "integer" }
  }
}
