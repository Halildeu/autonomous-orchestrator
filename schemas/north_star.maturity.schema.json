{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/north_star.maturity.schema.json",
  "title": "north_star.maturity.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "levels"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "levels": {
      "type": "array",
      "items": { "$ref": "#/$defs/level" },
      "default": []
    },
    "tracking": { "$ref": "#/$defs/tracking" }
  },
  "$defs": {
    "level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "criteria"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "min_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "tracking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated_at",
        "workspace_root",
        "mode",
        "source_eval_ref",
        "score",
        "coverage",
        "current_level_id",
        "current_level_label",
        "dimensions",
        "notes"
      ],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "workspace_root": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 },
        "source_eval_ref": { "type": "string", "minLength": 1 },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "current_level_id": { "type": "string", "minLength": 1 },
        "current_level_label": { "type": "string", "minLength": 1 },
        "dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/dimension_score" },
          "default": []
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "dimension_score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "lens_id", "status", "score"],
      "properties": {
        "dimension": { "type": "string", "enum": ["A", "B", "C", "D", "E", "F"] },
        "lens_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["OK", "WARN", "FAIL", "UNKNOWN"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
