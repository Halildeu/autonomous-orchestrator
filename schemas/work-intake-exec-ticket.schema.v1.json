{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/work-intake-exec-ticket.schema.v1.json",
  "title": "Work Intake Exec Ticket",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "generated_at",
    "workspace_root"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "trace_meta": { "$ref": "https://example.com/schemas/trace-meta.schema.v1.json" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "intake_id": { "type": "string", "minLength": 1 },
          "trace_meta": { "$ref": "https://example.com/schemas/trace-meta.schema.v1.json" }
        }
      }
    }
  }
}
