OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
# Gemini (preferred) — Google GenAI quickstart uses GEMINI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
# Legacy alias (optional)
GOOGLE_API_KEY=YOUR_GEMINI_KEY_HERE
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY_HERE
# Qwen / DashScope (preferred) — OpenAI-compatible endpoint
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_KEY_HERE
# Legacy alias (optional)
QWEN_API_KEY=YOUR_DASHSCOPE_KEY_HERE
# xAI (Grok) — OpenAI-compatible endpoint
XAI_API_KEY=YOUR_XAI_KEY_HERE
KERNEL_API_TOKEN=YOUR_TOKEN_HERE
KERNEL_API_HMAC_SECRET=YOUR_HMAC_SECRET_HERE
KERNEL_API_AUTH_MODE=bearer
KERNEL_API_RATE_LIMIT_PER_MINUTE=60
KERNEL_API_MAX_CONCURRENT=4
KERNEL_API_LLM_LIVE=0
