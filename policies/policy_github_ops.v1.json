{
  "version": "v1",
  "live_gate": {
    "enabled": false,
    "require_env_key_present": true,
    "env_flag": "KERNEL_API_GITHUB_LIVE",
    "env_key": "GITHUB_TOKEN"
  },
  "allowed_ops": [
    "pr_list",
    "pr_open",
    "pr_update",
    "merge",
    "deploy_trigger",
    "status_poll"
  ],
  "auth": {
    "mode": "bearer",
    "token_env": "GITHUB_TOKEN"
  },
  "retry_count": 0,
  "job": {
    "keep_last_n": 50,
    "ttl_seconds": 604800,
    "poll_interval_seconds": 300
  },
  "notes": [
    "network_default_off"
  ]
}
