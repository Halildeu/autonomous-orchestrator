{
  "version": "v1",
  "eval_lenses_enabled": [
    "trend",
    "integrity_compat",
    "ai_ops_fit",
    "github_ops_release",
    "operability"
  ],
  "trend_best_practice": {
    "min_coverage_ok": 0.5,
    "min_coverage_warn": 0.2
  },
  "integrity_compat": {
    "min_score_ok": 1.0,
    "min_score_warn": 0.5
  },
  "ai_ops_fit": {
    "required_fields": [
      "context_pack_present",
      "provider_policy_pinned",
      "secrets_redacted"
    ],
    "min_score_ok": 1.0,
    "min_score_warn": 0.5
  },
  "github_ops_release": {
    "required_fields": [
      "github_ops_policy_present",
      "github_ops_network_default_off",
      "release_policy_present",
      "github_jobs_index_present",
      "release_manifest_present"
    ],
    "min_score_ok": 1.0,
    "min_score_warn": 0.5
  },
  "operability": {
    "required_fields": [
      "script_budget_present",
      "doc_nav_present",
      "airunner_jobs_present",
      "pdca_cursor_present",
      "heartbeat_present",
      "work_intake_present",
      "integrity_present"
    ],
    "min_score_ok": 1.0,
    "min_score_warn": 0.5,
    "weights": {
      "simplicity": 0.34,
      "sustainability": 0.33,
      "continuity": 0.33
    }
  }
}
