{
  "version": "v1",
  "defaults": {
    "enabled": false,
    "timeout_seconds": 20,
    "max_request_bytes": 65536,
    "max_response_bytes": 131072,
    "retry_count": 0,
    "allow_models": ["*"]
  },
  "providers": {
    "deepseek": {
      "enabled": true,
      "expected_env_keys": ["DEEPSEEK_API_KEY"],
      "allow_models": ["deepseek-chat", "deepseek-reasoner"],
      "default_model": "deepseek-chat"
    },
    "google": {
      "enabled": true,
      "expected_env_keys": ["GEMINI_API_KEY", "GOOGLE_API_KEY"],
      "allow_models": ["gemini-1.5-pro", "gemini-2.0-flash"],
      "default_model": "gemini-2.0-flash"
    },
    "openai": {
      "enabled": false,
      "expected_env_keys": ["OPENAI_API_KEY"],
      "allow_models": ["gpt-4o-mini"],
      "default_model": "gpt-4o-mini"
    },
    "qwen": {
      "enabled": false,
      "expected_env_keys": ["DASHSCOPE_API_KEY", "QWEN_API_KEY"],
      "allow_models": ["qwen-plus", "qwen2.5-72b-instruct"],
      "default_model": "qwen-plus"
    },
    "xai": {
      "enabled": false,
      "expected_env_keys": ["XAI_API_KEY"],
      "allow_models": ["grok-4-latest"],
      "default_model": "grok-4-latest"
    }
  },
  "live_gate": {
    "policy_live_enabled": false,
    "require_env_key_present": true,
    "require_explicit_live_flag": true,
    "explicit_live_flag_env": "KERNEL_API_LLM_LIVE"
  }
}
