{
  "version": "v1",
  "enabled": true,
  "shortlist": {
    "match_fields": [
      "intent",
      "artifact_type"
    ],
    "max_candidates": 10
  },
  "tie_break": {
    "mode": "pack_id_lexicographic"
  },
  "hard_conflict_behavior": "fail",
  "soft_conflict_behavior": "warn",
  "selection_trace": {
    "enabled": true,
    "out_path": ".cache/index/pack_selection_trace.v1.json"
  },
  "fail_action": "warn"
}
