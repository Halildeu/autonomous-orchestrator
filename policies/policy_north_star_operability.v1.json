{
  "version": "v1",
  "heartbeat_expectation_mode": "ALWAYS",
  "thresholds": {
    "hard_exceeded_must_be": 0,
    "soft_target": 0,
    "soft_warn": 1,
    "placeholders_warn": 25,
    "placeholders_fail": 200,
    "docs_ops_md_count_warn": 40,
    "docs_ops_md_count_fail": 80,
    "docs_ops_md_bytes_warn": 250000,
    "docs_ops_md_bytes_fail": 500000,
    "repo_md_total_count_warn": 300,
    "repo_md_total_count_fail": 800,
    "docs_unmapped_md_warn": 1,
    "docs_unmapped_md_fail": 5,
    "jobs_stuck_warn": 1,
    "jobs_stuck_fail": 5,
    "jobs_fail_warn": 3,
    "jobs_fail_fail": 10,
    "pdca_cursor_stale_hours_warn": 24,
    "pdca_cursor_stale_hours_fail": 72,
    "heartbeat_stale_seconds_warn": 1800,
    "heartbeat_stale_seconds_fail": 7200,
    "intake_new_items_per_day_warn": 25,
    "intake_new_items_per_day_fail": 100,
    "suppressed_per_day_warn": 200
  },
  "signals": {
    "script_budget": true,
    "doc_nav_placeholders": true,
    "docs_hygiene": true,
    "docs_drift": true,
    "airunner_jobs": true,
    "pdca_cursor": true,
    "airunner_heartbeat": true,
    "work_intake_noise": true,
    "integrity_pass_required": true
  },
  "docs_drift_mapping": {
    "include_extension_manifest_refs": true,
    "view_doc_allowlist_globs": [
      ".gemini/**/*.md",
      "docs/ARCHITECTURE/**/*.md",
      "docs/DECISIONS/**/*.md",
      "docs/OPERATIONS/**/*.md",
      "extensions/**/README.md",
      "fixtures/**/*.md",
      "modules/**/README.md",
      "roadmaps/PROJECTS/**/*.md",
      "tenant/**/*.md",
      "templates/**/*.md"
    ],
    "exclude_legacy_redirect_stubs": true,
    "exclude_archive_only_banners": true,
    "root_readme_mode": "mapped",
    "root_changelog_mode": "mapped"
  },
  "classification": {
    "FAIL_if": {
      "hard_exceeded_gt": 0,
      "integrity_fail": true,
      "jobs_stuck_gt": "jobs_stuck_fail",
      "pdca_cursor_stale_hours_gt": "pdca_cursor_stale_hours_fail",
      "heartbeat_stale_seconds_gt": "heartbeat_stale_seconds_fail",
      "placeholders_gt": "placeholders_fail",
      "docs_ops_md_count_gt": "docs_ops_md_count_fail",
      "docs_ops_md_bytes_gt": "docs_ops_md_bytes_fail",
      "repo_md_total_count_gt": "repo_md_total_count_fail",
      "docs_unmapped_md_gt": "docs_unmapped_md_fail",
      "intake_new_items_per_day_gt": "intake_new_items_per_day_fail"
    },
    "WARN_if": {
      "soft_exceeded_gt": 0,
      "jobs_fail_gt": "jobs_fail_warn",
      "jobs_stuck_gt": "jobs_stuck_warn",
      "pdca_cursor_stale_hours_gt": "pdca_cursor_stale_hours_warn",
      "heartbeat_stale_seconds_gt": "heartbeat_stale_seconds_warn",
      "placeholders_gt": "placeholders_warn",
      "docs_ops_md_count_gt": "docs_ops_md_count_warn",
      "docs_ops_md_bytes_gt": "docs_ops_md_bytes_warn",
      "repo_md_total_count_gt": "repo_md_total_count_warn",
      "docs_unmapped_md_gt": "docs_unmapped_md_warn",
      "intake_new_items_per_day_gt": "intake_new_items_per_day_warn",
      "suppressed_per_day_gt": "suppressed_per_day_warn"
    }
  },
  "gap_rules": {
    "hard_exceeded_gt": "INCIDENT:MAINTAINABILITY_BLOCKER",
    "integrity_fail": "INCIDENT:INTEGRITY_DRIFT",
    "soft_exceeded_gt": "PROJECT:MAINTAINABILITY_PLAN_ONLY",
    "jobs_stuck_gt": "TICKET:JOB_LIFECYCLE_HYGIENE",
    "jobs_fail_gt": "TICKET:JOB_FAILURE_TRIAGE",
    "pdca_cursor_stale_hours_gt": "TICKET:PDCA_STALENESS",
    "heartbeat_stale_seconds_gt": "INCIDENT:RUNNER_STALLED",
    "placeholders_gt": "TICKET:DOC_PLACEHOLDER_REVIEW",
    "docs_ops_md_count_gt": "TICKET:DOCS_SPRAWL",
    "docs_ops_md_bytes_gt": "TICKET:DOCS_SPRAWL",
    "repo_md_total_count_gt": "PROJECT:DOCS_HYGIENE_REFACTOR",
    "docs_unmapped_md_gt_warn": "TICKET:DOCS_DRIFT_UNMAPPED_MD",
    "docs_unmapped_md_gt_fail": "PROJECT:DOCS_DRIFT_REFACTOR",
    "intake_new_items_per_day_gt": "TICKET:NOISE_CONTROL",
    "suppressed_per_day_gt": "TICKET:NOISE_CONTROL"
  },
  "fail_action": "warn"
}
